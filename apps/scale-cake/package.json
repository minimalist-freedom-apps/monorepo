{
    "name": "@minimalist-apps/scale-cake",
    "version": "1.0.0",
    "description": "Cake ingredient calculator — scale recipes by pan diameter",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite",
        "dev:android": "APP_DIR=$PWD bun run --filter @minimalist-apps/android-build dev",
        "build": "vite build",
        "build:android": "APP_DIR=$PWD bun run --filter @minimalist-apps/android-build build",
        "build:android:debug": "APP_DIR=$PWD bun run --filter @minimalist-apps/android-build build:debug",
        "build:android:sign": "APP_DIR=$PWD bun run --filter @minimalist-apps/android-build sign",
        "preview": "vite preview",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@capacitor/core": "^7.2.0",
        "@minimalist-apps/components": "workspace:*",
        "@minimalist-apps/mobile-native": "workspace:*",
        "react": "^19.0.0",
        "react-dom": "^19.0.0"
    },
    "devDependencies": {
        "@capacitor/android": "^7.2.0",
        "@capacitor/cli": "^7.2.0",
        "@minimalist-apps/requirements": "workspace:*",
        "@minimalist-apps/tsconfig": "workspace:*",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "@vitejs/plugin-react": "^4.3.0",
        "typescript": "^5.3.0",
        "vite": "^7.3.1"
    }
}
