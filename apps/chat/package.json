{
    "name": "@minimalist-apps/chat",
    "version": "1.0.0",
    "description": "Minimalist Chat app",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite",
        "dev:android": "APP_DIR=$PWD bun run --filter @minimalist-apps/android-build dev",
        "build": "vite build",
        "build:android": "APP_DIR=$PWD bun run --filter @minimalist-apps/android-build build",
        "build:android:debug": "APP_DIR=$PWD bun run --filter @minimalist-apps/android-build build:debug",
        "build:android:sign": "APP_DIR=$PWD bun run --filter @minimalist-apps/android-build sign",
        "preview": "vite preview",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@capacitor/core": "^7.2.0",
        "@evolu/common": "git+https://github.com/evoluhq/evolu.git#common-v8",
        "@minimalist-apps/connect": "workspace:*",
        "@minimalist-apps/components": "workspace:*",
        "@minimalist-apps/fragment-debug": "workspace:*",
        "@minimalist-apps/fragment-evolu": "workspace:*",
        "@minimalist-apps/fragment-local-storage": "workspace:*",
        "@minimalist-apps/fragment-navigator": "workspace:*",
        "@minimalist-apps/fragment-settings": "workspace:*",
        "@minimalist-apps/fragment-theme": "workspace:*",
        "@minimalist-apps/local-storage": "workspace:*",
        "@minimalist-apps/mini-store": "workspace:*",
        "@minimalist-apps/mobile-native": "workspace:*",
        "@minimalist-apps/navigator": "workspace:*",
        "@minimalist-apps/type-utils": "workspace:*",
        "@minimalist-apps/window": "workspace:*",
        "react": "^19.0.0",
        "react-dom": "^19.0.0"
    },
    "devDependencies": {
        "@capacitor/android": "^7.2.0",
        "@capacitor/cli": "^7.2.0",
        "@minimalist-apps/requirements": "workspace:*",
        "@minimalist-apps/tsconfig": "workspace:*",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "@vitejs/plugin-react": "^4.3.0",
        "typescript": "^5.3.0",
        "vite": "^7.3.1"
    }
}
